---
/* Reusable card wrapper for homepage information sections. */

interface Props {
  title: string;
  label: string;
}

const { label, title } = Astro.props;
---

<section
  class="relative h-full overflow-hidden rounded-2xl border border-slate-200/80 bg-white/90 p-6 shadow-sm shadow-slate-200/80 backdrop-blur dark:border-slate-700/80 dark:bg-slate-900/85 dark:shadow-slate-950/40"
>
  <div class="absolute inset-x-0 top-0 h-1 bg-cyan-700/80 dark:bg-cyan-300/70">
  </div>
  <p
    class="mb-2 font-mono text-[0.68rem] uppercase tracking-[0.24em] text-cyan-800 dark:text-cyan-300"
  >
    {label}
  </p>
  <h3
    class="mb-4 text-xl font-semibold tracking-tight text-slate-950 dark:text-stone-50"
  >
    {title}
  </h3>
  <div
    class="space-y-3 leading-7 text-slate-700 dark:text-slate-300 [&_a]:font-medium [&_a]:text-cyan-800 [&_a]:underline-offset-2 [&_a:hover]:text-cyan-950 [&_a:hover]:underline dark:[&_a]:text-cyan-300 dark:[&_a:hover]:text-cyan-100 [&_code]:rounded-md [&_code]:border [&_code]:border-slate-200 [&_code]:bg-stone-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-sm dark:[&_code]:border-slate-700 dark:[&_code]:bg-slate-800 dark:[&_code]:text-slate-100 [&_li]:pl-1 [&_small]:text-slate-500 dark:[&_small]:text-slate-400 [&_strong]:text-slate-950 dark:[&_strong]:text-stone-50 [&_ul]:list-disc [&_ul]:space-y-1 [&_ul]:pl-5"
  >
    <slot />
  </div>
</section>
