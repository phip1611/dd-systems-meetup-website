---
/* Reusable card wrapper for homepage information sections. */

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section
  class="h-full rounded-xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70"
>
  <h3 class="mb-4 text-xl font-semibold tracking-tight text-slate-950">
    {title}
  </h3>
  <div
    class="space-y-3 text-slate-700 [&_a]:font-medium [&_a]:text-blue-700 [&_a]:underline-offset-2 hover:[&_a]:text-blue-900 hover:[&_a]:underline [&_code]:rounded [&_code]:bg-slate-100 [&_code]:px-1 [&_code]:py-0.5 [&_code]:text-sm [&_li]:pl-1 [&_small]:text-slate-500 [&_ul]:list-disc [&_ul]:space-y-1 [&_ul]:pl-5"
  >
    <slot />
  </div>
</section>
