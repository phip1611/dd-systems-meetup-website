---
/* Renders one past meetup entry as an expandable disclosure panel. */

import type { PastMeetup } from "../data/meetups";

interface Props {
  meetup: PastMeetup;
  expanded: boolean;
}

const { meetup, expanded } = Astro.props;
---

<details
  class="group relative overflow-hidden rounded-xl border border-slate-200 bg-stone-50/80"
  open={expanded}
>
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 text-left transition-colors hover:bg-cyan-50/70 [&::-webkit-details-marker]:hidden"
  >
    <span class="min-w-0 font-medium text-slate-950">
      {meetup.label}
    </span>
    <svg
      aria-hidden="true"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="size-5 shrink-0 text-slate-500 transition-transform group-open:rotate-180"
    >
      <path
        fill-rule="evenodd"
        d="M5.22 7.22a.75.75 0 0 1 1.06 0L10 10.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 8.28a.75.75 0 0 1 0-1.06Z"
        clip-rule="evenodd"></path>
    </svg>
  </summary>
  <div
    class="ml-5 space-y-3 border-l border-dashed border-slate-300 px-5 pb-5 text-sm leading-6 text-slate-700 [&_a]:font-medium [&_a]:text-cyan-800 [&_a]:underline-offset-2 [&_a:hover]:text-cyan-950 [&_a:hover]:underline [&_ol]:list-decimal [&_ol]:space-y-1 [&_ol]:pl-5"
  >
    <p set:html={meetup.introHtml} />
    {
      meetup.talks.length > 0 && (
        <ol>
          {meetup.talks.map((talk) => (
            <li>
              <strong set:html={talk.title} />
              {" \u2013 "}
              <Fragment set:html={talk.speakerHtml} />
              {talk.link && (
                <>
                  {" ("}
                  <a href={talk.link.href} title={talk.link.title}>
                    {talk.link.label}
                  </a>
                  {")"}
                </>
              )}
            </li>
          ))}
        </ol>
      )
    }
    {meetup.outroHtml && <p set:html={meetup.outroHtml} />}
    {
      meetup.images?.map((image) => (
        <>
          <img
            src={image.src}
            alt={image.alt}
            title={image.title}
            class="w-full rounded-lg border border-slate-200"
          />
          {image.credit && (
            <div class="text-right text-xs text-slate-500">{image.credit}</div>
          )}
        </>
      ))
    }
  </div>
</details>
